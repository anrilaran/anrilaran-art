@echo off
chcp 65001 > nul

echo [АУДИТ] Текущее состояние репозитория:
echo --------------------------------------------------
git status
echo --------------------------------------------------
echo Если всё верно, нажмите любую клавишу для продолжения деплоя. 
echo Если видите лишние файлы — закройте это окно терминала.
pause > nul

echo.
echo [1/3] Добавление файлов в индекс...
git add .

echo [2/3] Введите описание изменений (commit message) и нажмите Enter:
set /p msg="> "

git commit -m "%msg%"

echo [3/3] Отправка на GitHub для автоматического деплоя в Cloudflare Pages...
git push origin main

echo.
echo [ПРОВЕРКА] Финальный статус:
git status

echo Деплой завершен.
pause